{
  "name": "weather-curve",
  "version": "2.1.0",
  "description": "A simple weather app to help you plan your day.",
  "author": "Caleb Dudley",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build-preview": "yarn build && yarn preview",
    "format:check": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "checks-before-push": "yarn lint && yarn format:check && yarn type-check",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish --no-git-tag",
    "update-version": "yarn changeset:version",
    "lint": "eslint --max-warnings 100",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "@sentry/react": "^10.47.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.474.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "yarn@4.13.0"
}
